# Optional aggregate – each service folder has its own .env.example.
# Either copy this whole file into each folder as .env, or cp .env.example .env per folder.

# ---------- PostgreSQL ----------
# No POSTGRES_DB – create databases later (first boot still has a default DB named like POSTGRES_USER)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev_postgres

# ---------- Redis ----------
REDIS_PASSWORD=dev_redis

# ---------- MinIO (S3-compatible) ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=dev_minio_123

# ---------- MySQL ----------
# No MYSQL_DATABASE – no DB on init; create with CREATE DATABASE when needed
MYSQL_ROOT_PASSWORD=dev_mysql

# Optional – override host ports if already in use
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MYSQL_PORT=3306
# Mailpit – if 1025/8025 busy, use e.g. 1026/8026 in mailpit/.env
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
